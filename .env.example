# LLM (Itinerary Agent) - OpenAI 또는 OpenRouter (Gemini 등)
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Gemini 3.1 Pro via OpenRouter 예시:
# OPENAI_API_KEY=sk-or-v1-xxxx
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=google/gemini-3.1-pro-preview

# A2A Agent URLs (Docker 시 자동 설정)
FLIGHT_AGENT_URL=http://localhost:9001
ITINERARY_AGENT_URL=http://localhost:9002
ACCOMMODATION_AGENT_URL=http://localhost:9003
RENTAL_CAR_AGENT_URL=http://localhost:9004
TRANSIT_AGENT_URL=http://localhost:9005
BOOKING_AGENT_URL=http://localhost:9006

# Flight APIs (무료 한도 초과 전 자동 중단)
# Amadeus: https://developers.amadeus.com (월 2000회 무료) - 권장
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# AMADEUS_BASE_URL: Test 기본값. 프로덕션은 https://api.amadeus.com
# AMADEUS_BASE_URL=https://test.api.amadeus.com
# Kiwi Tequila: 초대제, 일반 가입 어려움
KIWI_API_KEY=
# RapidAPI Skyscanner: RapidAPI에서 제공 중단됨
RAPIDAPI_KEY=
# flightapi.io: https://www.flightapi.io (100회/월 무료) - RapidAPI 대안
FLIGHTAPI_KEY=

# MCP Server URLs
FLIGHT_MCP_URL=http://localhost:8001/mcp
HOTEL_MCP_URL=http://localhost:8002/mcp
RENTAL_CAR_MCP_URL=http://localhost:8003/mcp
TRANSIT_MCP_URL=http://localhost:8004/mcp
